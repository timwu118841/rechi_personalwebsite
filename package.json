{
  "name": "rechi-legal-notes",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "start": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "npm run content:validate && ASTRO_TELEMETRY_DISABLED=1 astro check && ASTRO_TELEMETRY_DISABLED=1 astro build && npm run verify:build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "check": "ASTRO_TELEMETRY_DISABLED=1 astro check",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:ci": "npm run test:e2e",
    "content:validate": "node scripts/validate-content.mjs",
    "deploy:validate": "node scripts/validate-deploy-env.mjs",
    "content:import": "node scripts/import-content.mjs",
    "verify:build": "node scripts/verify-build.mjs",
    "quality": "npm run format:check && npm run lint && npm run check && npm run test && npm run build"
  },
  "dependencies": {
    "@astrojs/markdoc": "latest",
    "@astrojs/react": "latest",
    "@astrojs/rss": "latest",
    "@astrojs/vercel": "^11.0.2",
    "@supabase/supabase-js": "^2.110.2",
    "@tiptap/extension-image": "3.27.3",
    "@tiptap/extension-link": "3.27.3",
    "@tiptap/extension-underline": "3.27.3",
    "@tiptap/react": "3.27.3",
    "@tiptap/starter-kit": "3.27.3",
    "astro": "latest",
    "marked": "^18.0.6",
    "react": "latest",
    "react-dom": "latest",
    "sanitize-html": "^2.17.5",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@astrojs/check": "latest",
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "latest",
    "@playwright/test": "^1.61.1",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@types/sanitize-html": "^2.16.1",
    "eslint": "latest",
    "eslint-plugin-astro": "1.5.0",
    "globals": "latest",
    "prettier": "latest",
    "prettier-plugin-astro": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vitest": "latest"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "overrides": {
    "@vercel/routing-utils": {
      "path-to-regexp": "6.3.0"
    },
    "esbuild": "0.28.1"
  }
}
