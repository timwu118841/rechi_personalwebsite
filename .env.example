# Public site
SITE_URL=https://example.com
PUBLIC_SITE_NAME=法律實務筆記
PUBLIC_GOOGLE_SITE_VERIFICATION=
PUBLIC_PREVIEW=false

# Supabase content, authentication and media
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Compatibility password sign-in; Google OAuth is always available when Supabase is configured.
PUBLIC_ADMIN_PASSWORD_LOGIN=true
# Server-only. Never expose this value to browser code or prefix it with PUBLIC_.
SUPABASE_SECRET_KEY=
# Add approved users to public.admin_users after creating them in Supabase Auth.

# Editorial worker and Notion root sync
# Use a random value of at least 16 characters. Vercel sends it as Authorization: Bearer <value>.
CRON_SECRET=
NOTION_EDITORIAL_ENABLED=false
# Server-only Notion internal integration installation access token (API key/secret).
NOTION_TOKEN=
# UUID from the shared editorial root page URL; dashed or undashed forms are accepted.
NOTION_ROOT_PAGE_ID=
# Pinned by the implementation. Do not change without upgrading the Notion adapter.
NOTION_VERSION=2026-03-11

# Retained rollout controls. Current defaults are service and legacy.
CONTENT_PUBLIC_READ_MODE=service
NOTION_PUBLICATION_MODE=legacy

# Local-only escape hatch used by build and tests. Never enable in Vercel production.
ALLOW_FIXTURE_CONTENT=false

# Optional privacy-friendly analytics (Umami-compatible)
PUBLIC_UMAMI_WEBSITE_ID=
PUBLIC_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
