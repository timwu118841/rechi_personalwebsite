---
import { Image } from 'astro:assets';
import { render } from 'astro:content';
import LegalDisclaimer from '@/components/LegalDisclaimer.astro';
import TagList from '@/components/TagList.astro';
import { siteConfig } from '@/config/site';
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  articleSlug,
  formatDate,
  getCategoryMap,
  getContentTypeMap,
  getPublishedArticles,
  readingTimeMinutes,
  type ArticleEntry,
} from '@/lib/articles';

export async function getStaticPaths() {
  const articles = await getPublishedArticles();
  return articles.map((article) => ({
    params: { slug: articleSlug(article) },
    props: { article },
  }));
}

interface Props {
  article: ArticleEntry;
}
const { article } = Astro.props;
const { Content } = await render(article);
const slug = articleSlug(article);
const canonical = article.data.canonicalUrl || new URL(`/articles/${slug}/`, Astro.site).toString();
const minutes = readingTimeMinutes(article.body || '');
const [categories, contentTypes] = await Promise.all([
  getCategoryMap({ includeHidden: true }),
  getContentTypeMap(),
]);
const category = categories.get(article.data.category);
const categoryName = category?.name || article.data.category;
const contentType = contentTypes.get(article.data.contentType);
const contentTypeName = contentType?.name || article.data.contentType;
const articleUrl = new URL(`/articles/${slug}/`, Astro.site).toString();
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: article.data.title,
    description: article.data.description,
    datePublished: article.data.publishedAt.toISOString(),
    dateModified: (article.data.updatedAt || article.data.publishedAt).toISOString(),
    mainEntityOfPage: articleUrl,
    author: { '@type': 'Person', name: siteConfig.author.name },
    publisher: { '@type': 'Person', name: siteConfig.author.name },
    image: article.data.cover
      ? new URL(article.data.cover.src, Astro.site).toString()
      : new URL('/social-card.svg', Astro.site).toString(),
    articleSection: categoryName,
    genre: contentTypeName,
    keywords: article.data.tags.join(', '),
    inLanguage: 'zh-Hant-TW',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: '首頁', item: new URL('/', Astro.site).toString() },
      {
        '@type': 'ListItem',
        position: 2,
        name: '文章',
        item: new URL('/articles/', Astro.site).toString(),
      },
      { '@type': 'ListItem', position: 3, name: article.data.title, item: articleUrl },
    ],
  },
];
---

<BaseLayout
  title={article.data.seoTitle || article.data.title}
  description={article.data.seoDescription || article.data.description}
  canonical={canonical}
  image={article.data.cover?.src}
  type="article"
  publishedAt={article.data.publishedAt}
  updatedAt={article.data.updatedAt}
  jsonLd={jsonLd}
>
  <article data-pagefind-body data-article-slug={slug}>
    <header class="article-header reading-container">
      <p class="eyebrow">{contentTypeName} · {categoryName}</p>
      <h1 data-pagefind-meta="title">{article.data.title}</h1>
      <p class="article-dek" data-pagefind-meta="description">{article.data.description}</p>
      <div class="article-byline">
        <span class="author-chip"
          ><span class="author-avatar" aria-hidden="true">R</span>{siteConfig.author.name}</span
        >
        <time datetime={article.data.publishedAt.toISOString()}
          >{formatDate(article.data.publishedAt)}</time
        >
        {article.data.updatedAt && <span>更新於 {formatDate(article.data.updatedAt)}</span>}
        <span>{minutes} 分鐘閱讀</span>
      </div>
    </header>
    {
      article.data.cover && (
        <div class="article-cover">
          <Image
            src={article.data.cover}
            alt={article.data.coverAlt || ''}
            widths={[768, 1200, 1600]}
            sizes="(max-width: 1024px) 100vw, 1024px"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      )
    }
    <div class="reading-container">
      <div class="prose"><Content /></div>
      <div class="article-end">
        <TagList tags={article.data.tags} />
        <div data-pagefind-ignore>
          <LegalDisclaimer />
          <div class="share-row" aria-label="分享文章">
            <strong>分享：</strong>
            <a
              href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(articleUrl)}`}
              target="_blank"
              rel="noopener noreferrer">Facebook</a
            >
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(articleUrl)}`}
              target="_blank"
              rel="noopener noreferrer">LinkedIn</a
            >
            <a
              href={`mailto:?subject=${encodeURIComponent(article.data.title)}&body=${encodeURIComponent(articleUrl)}`}
              >Email</a
            >
          </div>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
