---
import LegalDisclaimer from '@/components/LegalDisclaimer.astro';
import TagList from '@/components/TagList.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatDate, readingTimeMinutes } from '@/lib/articles';
import { renderMarkdown, renderRichText } from '@/lib/content/markdown';
import { getPublicContentRepository } from '@/lib/content/repository';
import { articleCacheTag, articlePath, decodeSlugPathParam } from '@/lib/content/slug';

const slug = decodeSlugPathParam(Astro.params.slug || '');
const repository = getPublicContentRepository();
const [article, settings] = await Promise.all([
  repository.getPublishedArticle(slug),
  repository.getSiteSettings(),
]);
if (!article) {
  const redirect = await repository.getArticleSlugRedirect(slug);
  if (redirect) return Astro.redirect(articlePath(redirect), 301);
  return Astro.rewrite('/404');
}
if (Astro.cache.enabled)
  Astro.cache.set({
    maxAge: 86400,
    swr: 604800,
    tags: ['content', 'site-settings', articleCacheTag(article.slug)],
  });
const articleUrl = new URL(articlePath(article.slug), Astro.site).toString();
const canonical = article.canonicalUrl || articleUrl;
const image = article.cover || settings.defaultSocialImage;
const minutes = readingTimeMinutes(article.body);
const bodyHtml =
  article.bodyHtml ||
  (article.bodyJson ? renderRichText(article.bodyJson) : renderMarkdown(article.body));
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: article.title,
    description: article.description,
    datePublished: article.publishedAt.toISOString(),
    dateModified: (article.updatedAt || article.publishedAt).toISOString(),
    mainEntityOfPage: articleUrl,
    author: { '@type': 'Person', name: settings.authorName },
    publisher: { '@type': 'Person', name: settings.authorName },
    image: new URL(image?.url || '/social-card.svg', Astro.site).toString(),
    articleSection: article.categoryName,
    genre: article.contentTypeName,
    keywords: article.tags.join(', '),
    inLanguage: 'zh-Hant-TW',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: '首頁', item: new URL('/', Astro.site).toString() },
      {
        '@type': 'ListItem',
        position: 2,
        name: '文章',
        item: new URL('/articles/', Astro.site).toString(),
      },
      { '@type': 'ListItem', position: 3, name: article.title, item: articleUrl },
    ],
  },
];
---

<BaseLayout
  siteSettings={settings}
  title={article.seoTitle || article.title}
  description={article.seoDescription || article.description}
  canonical={canonical}
  image={image?.url}
  type="article"
  publishedAt={article.publishedAt}
  updatedAt={article.updatedAt}
  jsonLd={jsonLd}
>
  <article data-article-slug={article.slug}>
    <header class="article-header container">
      <nav class="breadcrumbs" aria-label="麵包屑">
        <a href="/">首頁</a><span aria-hidden="true">/</span><a href="/articles/">文章</a><span
          aria-hidden="true">/</span
        ><span aria-current="page">{article.categoryName}</span>
      </nav><div class="article-heading-grid">
        <div class="article-heading-copy">
          <p class="eyebrow">{article.contentTypeName} · {article.categoryName}</p><h1>
            {article.title}
          </h1><p class="article-dek">{article.description}</p>
        </div><aside class="article-facts" aria-label="文章資訊">
          <span class="article-facts-label">Article note</span><dl>
            <div>
              <dt>作者</dt><dd>
                <span class="author-chip"
                  >{
                    settings.authorImage ? (
                      <img
                        class="author-avatar-image"
                        src={settings.authorImage.url}
                        alt=""
                        width={settings.authorImage.width}
                        height={settings.authorImage.height}
                      />
                    ) : (
                      <span class="author-avatar" aria-hidden="true">
                        {settings.authorName.slice(0, 1)}
                      </span>
                    )
                  }{settings.authorName}</span
                >
              </dd>
            </div><div>
              <dt>發布</dt><dd>
                <time datetime={article.publishedAt.toISOString()}
                  >{formatDate(article.publishedAt)}</time
                >
              </dd>
            </div>{
              article.updatedAt && (
                <div>
                  <dt>更新</dt>
                  <dd>{formatDate(article.updatedAt)}</dd>
                </div>
              )
            }<div><dt>閱讀</dt><dd>{minutes} 分鐘</dd></div>
          </dl>
        </aside>
      </div>
    </header>
    {
      image && (
        <div class="article-cover">
          <img
            src={image.url}
            alt={article.cover?.alt || image.alt}
            width={image.width}
            height={image.height}
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </div>
      )
    }
    <div class="container article-layout">
      <aside class="article-rail" aria-label="文章探索">
        <p class="eyebrow">Filed under</p><a href={`/categories/${article.category}/`}
          >{article.categoryName}</a
        ><span class="rail-rule" aria-hidden="true"></span><a href="/articles/">← 返回所有文章</a>
      </aside><div class="reading-container article-reading">
        <div class="prose" set:html={bodyHtml} /><div class="article-end">
          <div class="article-end-heading">
            <p class="eyebrow">Continue exploring</p><h2>延伸探索</h2>
          </div><TagList tags={article.tags} /><LegalDisclaimer /><div
            class="share-row"
            aria-label="分享文章"
          >
            <strong>分享這篇文章</strong><a
              href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(articleUrl)}`}
              target="_blank"
              rel="noopener noreferrer">Facebook <span aria-hidden="true">↗</span></a
            ><a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(articleUrl)}`}
              target="_blank"
              rel="noopener noreferrer">LinkedIn <span aria-hidden="true">↗</span></a
            ><a
              href={`mailto:?subject=${encodeURIComponent(article.title)}&body=${encodeURIComponent(articleUrl)}`}
              >Email <span aria-hidden="true">↗</span></a
            >
          </div>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
