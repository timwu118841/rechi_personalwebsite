---
import ArticleCard from '@/components/ArticleCard.astro';
import Pagination from '@/components/Pagination.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPublicContentRepository } from '@/lib/content/repository';
import { DEFAULT_PAGE_SIZE, pageCanonical, parsePage } from '@/lib/pagination';

const page = parsePage(Astro.url.searchParams.get('page'));
if (page === null) return Astro.rewrite('/404');
const repository = getPublicContentRepository();
const [result, settings] = await Promise.all([
  repository.listPublishedArticles({ page, pageSize: DEFAULT_PAGE_SIZE }),
  repository.getSiteSettings(),
]);
if (page > result.totalPages && result.totalItems > 0) return Astro.rewrite('/404');
if (Astro.cache.enabled)
  Astro.cache.set({
    maxAge: 86400,
    swr: 604800,
    tags: ['content', 'site-settings', 'article-list'],
  });
const canonical = pageCanonical('/articles/', page, Astro.site!);
---

<BaseLayout
  siteSettings={settings}
  title="所有文章"
  description="閱讀法律實務、制度觀察與工作經驗整理。"
  canonical={canonical}
>
  <header class="page-hero">
    <div class="container page-hero-grid">
      <div>
        <p class="page-index" aria-hidden="true">INDEX / 01</p><p class="eyebrow">
          All articles
        </p><h1>所有文章</h1>
      </div><div class="page-intro">
        <p>法律不只存在於法條裡，也存在於每一次判斷、溝通與選擇之中。</p><span
          >{result.totalItems} 篇公開文章</span
        >
      </div>
    </div>
  </header>
  <section class="section">
    <div class="container">
      {
        result.items.length > 0 ? (
          <>
            <>
              <div class="article-grid">
                {result.items.map((article) => (
                  <ArticleCard article={article} fallbackImage={settings.defaultSocialImage} />
                ))}
              </div>
              <Pagination page={page} totalPages={result.totalPages} basePath="/articles/" />
            </>
          </>
        ) : (
          <div class="empty-state">
            <>
              <h2>尚無公開文章</h2>
              <p>文章準備完成後會出現在這裡。</p>
            </>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
