---
import BaseLayout from '@/layouts/BaseLayout.astro';
Astro.response.status = 404;
// A route that directly returns a 404 Response can render this page without a cache API in dev.
Astro.cache?.set(false);
---

<BaseLayout title="找不到頁面" description="你造訪的頁面不存在或已被移動。" noindex={true}>
  <section class="section">
    <div class="reading-container empty-state error-state">
      <span class="error-code" aria-hidden="true">404</span><p class="eyebrow">Page not found</p><h1
      >
        這一頁找不到了
      </h1><p class="muted">網址可能已變更，或文章尚未公開。</p><div class="error-actions">
        <a class="button" href="/">回到首頁</a><a class="text-link" href="/articles/"
          >瀏覽所有文章</a
        >
      </div>
    </div>
  </section>
</BaseLayout>
