---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCategories, getPublishedArticles } from '@/lib/articles';
const articles = await getPublishedArticles();
const categories = (await getCategories()).map((category) => ({
  ...category,
  count: articles.filter((article) => article.data.category === category.slug).length,
}));
---

<BaseLayout title="文章分類" description="依主題探索法律實務筆記。">
  <header class="page-hero">
    <div class="container">
      <p class="eyebrow">Topics</p><h1>文章分類</h1><p>
        從實務、制度到職涯，用不同角度理解法律工作的現場。
      </p>
    </div>
  </header>
  <section class="section">
    <div class="container taxonomy-grid">
      {
        categories.map((category) => (
          <a class="taxonomy-card" href={`/categories/${category.slug}/`}>
            <div class="taxonomy-card-copy">
              <strong>{category.name}</strong>
              <p>{category.description}</p>
            </div>
            <span>{category.count} 篇文章 →</span>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
