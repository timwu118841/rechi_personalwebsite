---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPublicContentRepository } from '@/lib/content/repository';
const repository = getPublicContentRepository();
const [articles, categories] = await Promise.all([
  repository.listPublishedArticles({ pageSize: 1000 }),
  repository.listCategories(),
]);
const summaries = categories.map((category) => ({
  ...category,
  count: articles.items.filter((article) => article.category === category.slug).length,
}));
if (Astro.cache.enabled)
  Astro.cache.set({ maxAge: 86400, swr: 604800, tags: ['content', 'site-settings', 'taxonomies'] });
---

<BaseLayout title="文章分類" description="依主題探索法律實務筆記。"
  ><header class="page-hero">
    <div class="container page-hero-grid">
      <div>
        <p class="page-index" aria-hidden="true">INDEX / 02</p><p class="eyebrow">Topics</p><h1>
          文章分類
        </h1>
      </div><div class="page-intro">
        <p>從實務、制度到職涯，用不同角度理解法律工作的現場。</p><span
          >{summaries.length} 個閱讀入口</span
        >
      </div>
    </div>
  </header><section class="section">
    <div class="container taxonomy-grid">
      {
        summaries.map((category, index) => (
          <a class="taxonomy-card" href={`/categories/${category.slug}/`}>
            <>
              <span class="taxonomy-index" aria-hidden="true">
                {String(index + 1).padStart(2, '0')}
              </span>
              <div class="taxonomy-card-copy">
                <>
                  <strong>{category.name}</strong>
                  <p>{category.description}</p>
                </>
              </div>
              <span class="taxonomy-count">{category.count} 篇文章 →</span>
            </>
          </a>
        ))
      }
    </div>
  </section></BaseLayout
>
