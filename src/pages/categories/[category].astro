---
import ArticleCard from '@/components/ArticleCard.astro';
import Pagination from '@/components/Pagination.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPublicContentRepository } from '@/lib/content/repository';
import { DEFAULT_PAGE_SIZE, pageCanonical, parsePage } from '@/lib/pagination';
const page = parsePage(Astro.url.searchParams.get('page'));
if (page === null) return Astro.rewrite('/404');
const slug = Astro.params.category || '';
const repository = getPublicContentRepository();
const [categories, result, settings] = await Promise.all([
  repository.listCategories(),
  repository.listPublishedArticles({ category: slug, page, pageSize: DEFAULT_PAGE_SIZE }),
  repository.getSiteSettings(),
]);
const category = categories.find((item) => item.slug === slug);
if (!category || (page > result.totalPages && result.totalItems > 0)) return Astro.rewrite('/404');
if (Astro.cache.enabled)
  Astro.cache.set({
    maxAge: 86400,
    swr: 604800,
    tags: ['content', 'site-settings', 'taxonomies', `category:${slug}`],
  });
const basePath = `/categories/${slug}/`;
---

<BaseLayout
  siteSettings={settings}
  title={`${category.name}分類`}
  description={category.description}
  canonical={pageCanonical(basePath, page, Astro.site!)}
  ><header class="page-hero">
    <div class="container page-hero-grid">
      <div>
        <p class="page-index" aria-hidden="true">TOPIC</p><p class="eyebrow">Category</p><h1>
          {category.name}
        </h1>
      </div><div class="page-intro">
        <p>{category.description}</p><span>共 {result.totalItems} 篇文章</span>
      </div>
    </div>
  </header><section class="section">
    <div class="container">
      {
        result.items.length > 0 ? (
          <>
            <>
              <div class="article-grid">
                {result.items.map((article) => (
                  <ArticleCard article={article} fallbackImage={settings.defaultSocialImage} />
                ))}
              </div>
              <Pagination page={page} totalPages={result.totalPages} basePath={basePath} />
            </>
          </>
        ) : (
          <div class="empty-state">
            <>
              <h2>這個分類還沒有公開文章</h2>
              <p>文章發布後會自動出現在這裡。</p>
            </>
          </div>
        )
      }
    </div>
  </section></BaseLayout
>
