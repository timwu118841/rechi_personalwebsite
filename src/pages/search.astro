---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPublicContentRepository } from '@/lib/content/repository';
import { articlePath } from '@/lib/content/slug';

const query = (Astro.url.searchParams.get('q') || '').trim().slice(0, 100);
const results = query ? await getPublicContentRepository().searchPublishedArticles(query, 20) : [];
Astro.cache.set(false);
---

<BaseLayout title="站內搜尋" description="搜尋已發布的法律文章。" noindex={true}
  ><header class="page-hero">
    <div class="container page-hero-grid">
      <div>
        <p class="page-index" aria-hidden="true">INDEX / 04</p><p class="eyebrow">Search</p><h1>
          搜尋文章
        </h1>
      </div><div class="page-intro">
        <p>輸入法律概念、工作情境或文章主題，從已發布內容中找到線索。</p><span
          >最多顯示 20 筆結果</span
        >
      </div>
    </div>
  </header><section class="section">
    <div class="container search-shell">
      <form class="search-form" role="search" method="get">
        <label for="search-input">你想理解什麼？</label><div class="search-control">
          <svg aria-hidden="true" viewBox="0 0 24 24" width="22" height="22"
            ><circle cx="11" cy="11" r="6.5"></circle><path d="m16 16 4 4"></path></svg
          ><input
            id="search-input"
            name="q"
            type="search"
            aria-label="搜尋文章"
            autocomplete="off"
            value={query}
            placeholder="例如：契約、溝通、訴訟風險…"
            required
          /><button type="submit">搜尋 <span aria-hidden="true">→</span></button>
        </div>
      </form>{
        query && (
          <p class="search-status" aria-live="polite">
            {results.length
              ? `找到 ${results.length} 筆結果`
              : '找不到符合的文章，試試其他關鍵字。'}
          </p>
        )
      }<div class="search-results">
        {
          results.map((article) => (
            <article class="search-result">
              <>
                <p class="search-result-meta">
                  {article.categoryName} · {article.contentTypeName}
                </p>
                <h2>
                  <a href={articlePath(article.slug)}>{article.title}</a>
                </h2>
              </>
              <>
                <p>{article.description}</p>
                <a class="read-more" href={articlePath(article.slug)}>
                  閱讀全文 <span aria-hidden="true">↗</span>
                </a>
              </>
            </article>
          ))
        }
      </div>{
        query && !results.length && (
          <div class="empty-state">
            <p>
              也可以前往<a href="/articles/">所有文章</a>或<a href="/categories/">文章分類</a>
              探索內容。
            </p>
          </div>
        )
      }
    </div>
  </section><script
    is:inline
    define:vars={{ didSearch: Boolean(query), resultCount: results.length }}
  >
    if (didSearch) window.blogAnalytics?.track('site_search', { resultCount });
  </script></BaseLayout
>
