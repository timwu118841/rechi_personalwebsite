---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPublicContentRepository } from '@/lib/content/repository';
const tags = await getPublicContentRepository().listTags();
if (Astro.cache.enabled)
  Astro.cache.set({ maxAge: 86400, swr: 604800, tags: ['content', 'site-settings', 'taxonomies'] });
---

<BaseLayout title="文章標籤" description="依標籤探索法律實務筆記。"
  ><header class="page-hero">
    <div class="container page-hero-grid">
      <div>
        <p class="page-index" aria-hidden="true">INDEX / 03</p><p class="eyebrow">Tags</p><h1>
          文章標籤
        </h1>
      </div><div class="page-intro">
        <p>從關鍵概念切入，在不同文章之間找到相連的思考線索。</p><span>{tags.length} 個標籤</span>
      </div>
    </div>
  </header><section class="section">
    <div class="container taxonomy-grid">
      {
        tags.map((tag, index) => (
          <a class="taxonomy-card" href={`/tags/${encodeURIComponent(tag.name)}/`}>
            <>
              <>
                <span class="taxonomy-index" aria-hidden="true">
                  {String(index + 1).padStart(2, '0')}
                </span>
                <strong>#{tag.name}</strong>
              </>
              <span class="taxonomy-count">{tag.count} 篇文章 →</span>
            </>
          </a>
        ))
      }
    </div>
  </section></BaseLayout
>
