---
import Analytics from '@/components/Analytics.astro';
import SeoHead, { type Props as SeoProps } from '@/components/SeoHead.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import { getPublicContentRepository, type SiteSettings } from '@/lib/content/repository';
import '@/styles/global.css';

interface Props extends Omit<SeoProps, 'settings'> {
  bodyClass?: string;
  siteSettings?: SiteSettings;
}
const { bodyClass = '', siteSettings, ...seo } = Astro.props;
const settings = siteSettings || (await getPublicContentRepository().getSiteSettings());
---

<!doctype html>
<html lang="zh-Hant-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f3f0e8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#171e23" media="(prefers-color-scheme: dark)" />
    <script is:inline>
      (() => {
        try {
          const saved = localStorage.getItem('color-theme');
          document.documentElement.dataset.theme =
            saved || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        } catch {
          document.documentElement.removeAttribute('data-theme');
        }
      })();
    </script>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${settings.siteTitle} RSS`}
      href="/rss.xml"
    />
    <SeoHead settings={settings} {...seo} />
  </head>
  <body class={bodyClass}>
    <a class="skip-link" href="#main-content">跳到主要內容</a>
    <SiteHeader settings={settings} />
    <main id="main-content" tabindex="-1"><slot /></main>
    <SiteFooter settings={settings} />
    <Analytics />
  </body>
</html>
