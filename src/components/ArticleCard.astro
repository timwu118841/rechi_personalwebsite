---
import type { Article, MediaAsset } from '@/lib/content/repository';
import { formatDate, readingTimeMinutes } from '@/lib/articles';
import { articlePath } from '@/lib/content/slug';
import TagList from './TagList.astro';

interface Props {
  article: Article;
  fallbackImage?: MediaAsset;
}
const { article, fallbackImage } = Astro.props;
const image = article.cover || fallbackImage;
const minutes = readingTimeMinutes(article.body);
const articleUrl = articlePath(article.slug);
---

<article class="article-card">
  <a class="card-image" href={articleUrl} tabindex="-1" aria-hidden="true">
    {
      image ? (
        <img
          src={image.url}
          alt=""
          width={image.width}
          height={image.height}
          loading="lazy"
          decoding="async"
        />
      ) : (
        <span class="card-pattern" aria-hidden="true">
          <span>閱讀筆記</span>
        </span>
      )
    }
  </a>
  <div class="card-body">
    <div class="card-meta">
      <span>{article.contentTypeName} · {article.categoryName}</span>
      <span>{formatDate(article.publishedAt)}</span><span>{minutes} 分鐘閱讀</span>
    </div>
    <h3><a href={articleUrl}>{article.title}</a></h3>
    <p>{article.description}</p>
    <div class="card-footer">
      <TagList tags={article.tags.slice(0, 2)} />
      <a class="read-more" href={articleUrl} aria-label={`閱讀「${article.title}」`}>閱讀 →</a>
    </div>
  </div>
</article>
