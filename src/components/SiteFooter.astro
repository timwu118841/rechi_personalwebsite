---
import type { SiteSettings } from '@/lib/content/repository';
interface Props {
  settings: SiteSettings;
}
const { settings } = Astro.props;
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <p class="footer-title">{settings.siteTitle}</p><p class="footer-copy">
          {settings.siteDescription}
        </p>
      </div><nav class="footer-links" aria-label="頁尾導覽">
        <a href="/articles/">所有文章</a><a href="/categories/">文章分類</a><a href="/about/"
          >關於本站</a
        ><a href="/rss.xml">RSS</a><a href="/admin/" rel="nofollow">管理登入</a>
      </nav>
    </div>
    <div class="footer-bottom">
      <span>© {new Date().getFullYear()} {settings.authorName}</span><span
        >法律資訊與經驗分享，不構成個案法律意見。</span
      >
    </div>
  </div>
</footer>
